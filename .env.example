# Copy to .env.local for local dev (Vite loads .env, .env.local, etc.)
# Variables must use the VITE_ prefix to reach the browser bundle.

# state-api base URL (no trailing slash)
VITE_API_URL=http://localhost:8080

# Bearer token for /control writes (PUT/PATCH/POST). Leave empty for overlay-only dev.
VITE_STATE_API_TOKEN=dev-token

# Default room when route does not imply one (control uses ?room= override)
VITE_ROOM_ID=codes

# Sync state with backend (GET on load, debounced PUT from /control, WebSocket on overlays)
VITE_API_SYNC=true
